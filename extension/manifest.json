{
  "manifest_version": 3,
  "name": "Ghost Shield Injector",
  "version": "1.0.2",
  "description": "Zero-latency DOM prototype poisoner.",
  "permissions": ["activeTab", "scripting"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
